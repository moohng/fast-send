{
  "name": "fast-send-monorepo",
  "version": "1.0.0",
  "description": "Simple LAN file and text sharing tool",
  "author": "FastSend Team",
  "private": true,
  "workspaces": [
    "packages/client",
    "packages/server-go"
  ],
  "scripts": {
    "server": "cd packages/server-go && go run main.go",
    "client": "npm run dev --workspace=@fast-send/client",
    "check": "npm run check --workspaces",
    "build": "npm run build --workspace=@fast-send/client",
    "dev": "concurrently \"npm run client\" \"npm run server\"",
    "build:go": "cd packages/server-go && go build -o ../../out/FastSend.exe main.go",
    "build:go2": "cd packages/server-go && go build -ldflags=\"-s -w -H windowsgui\" -o ../../out/FastSend.exe main.go",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "10.1.0",
    "prettier": "3.8.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@types/react-window": "1.8.8",
    "react-virtualized-auto-sizer": "2.0.3",
    "react-virtuoso": "4.18.5",
    "react-window": "2.2.7",
    "spark-md5": "3.0.2"
  }
}
