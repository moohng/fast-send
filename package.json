{
  "name": "fast-send-monorepo",
  "version": "1.0.0",
  "description": "Simple LAN file and text sharing tool",
  "author": "FastSend Team",
  "private": true,
  "main": "electron/main.ts",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "server": "npm run dev --workspace=@fast-send/server",
    "client": "npm run dev --workspace=@fast-send/client",
    "check": "npm run check --workspaces",
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run client\" \"npm run electron:dev\"",
    "electron:dev": "electron -r ts-node/register .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "12.9.0",
    "bonjour-service": "1.3.0",
    "cors": "2.8.6",
    "electron-is-dev": "3.0.1",
    "express": "5.2.1",
    "multer": "2.1.1",
    "qrcode": "1.5.4",
    "qrcode-terminal": "0.12.0",
    "socket.io": "4.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "41.2.2",
    "electron-builder": "26.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
